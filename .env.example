# NHS PCA Pipeline — Environment Variables Template
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
AZURE_STORAGE_CONTAINER=your_container_name_here

# Azure SQL Database
AZURE_SQL_SERVER=your-server-name.database.windows.net
AZURE_SQL_DATABASE=your-database-name
AZURE_SQL_USERNAME=your-sql-admin-username
AZURE_SQL_PASSWORD=your-sql-password

# Airflow (used inside Docker Compose)
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False